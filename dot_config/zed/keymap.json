// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "bindings": {
      "cmd-d": "editor::DuplicateSelection",
      "cmd-shift-w": null,
      "fn-escape": "window::ShowNextWindowTab",
      "fn-shift-escape": "window::ShowPreviousWindowTab",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-o": "projects::OpenRecent",
      "cmd-b": "workspace::ToggleRightDock",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "cmd-alt-l": "editor::Format",
      "cmd-shift-l": "editor::SplitSelectionIntoLines",
      "cmd-d": "editor::DuplicateLineDown",
      "ctrl-g": ["editor::SelectNext", { "replace_newest": false }],
      "cmd-ctrl-g": "editor::SelectAllMatches",
      "cmd-shift-backspace": "editor::DeleteLine",
      "alt-q": [
        "editor::ToggleComments",
        {
          "advance_downwards": false,
        },
      ],
    },
    "unbind": {
      "cmd-:": [
        "editor::ToggleComments",
        {
          "advance_downwards": false,
        },
      ],
    },
  },
  {
    "context": "!ContextEditor > (Editor && mode == full)",
    "bindings": {
      "cmd-shift-w": "pane::RevealInProjectPanel",
    },
  },
]
