# Color theme
# A good light theme: Adwaita
# A good dark theme: Banana Blueberry
# To have the theme follow the current desktop environment's theme
# theme = light:Adwaita,dark:Banana Blueberry
theme = Banana Blueberry

# Unfocused splits
unfocused-split-fill = 222200

# Quick terminal settings
quick-terminal-screen = macos-menu-bar
quick-terminal-autohide = false

# Confirm on quit
confirm-close-surface = always

# Load keybinds
config-file = keybinds

# Tab settings
window-new-tab-position = end

# Save window state
window-save-state = always
