# Non-interactive shell setup (Claude Code, scripts, etc.)
# Full interactive setup lives in .shell/integrations/common.sh via .profile.
#
# Note: mise shims are added in common.sh AFTER `mise activate zsh` (which resets PATH).
# Adding them here would be pointless since activate wipes them.

# Suppress zoxide init-order warning (we intentionally init early, before .profile)
export _ZO_DOCTOR=0

# AWS Granted
alias assume=". assume"
