{{ if eq .hostname "raichu" -}}
# ---
# --- 1Password SSH key (raichu)
# ---
# Keep a persistent user ssh-agent at a fixed socket and make sure raichu's key
# (fetched from 1Password by the service account) is loaded into it. This makes
# the key available in every session and survives across logins; the first login
# after a reboot re-establishes it. The key lives only in agent memory.

export SSH_AUTH_SOCK="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/ssh-agent.socket"

ssh-add -l >/dev/null 2>&1
case $? in
    0) ;;                                    # a key is already loaded — done
    1) ~/.shell/scripts/load-ssh-key ;;      # agent running but empty — load the key
    2)                                       # no/stale agent — (re)start it, then load
        rm -f "$SSH_AUTH_SOCK"
        ssh-agent -a "$SSH_AUTH_SOCK" >/dev/null 2>&1
        ~/.shell/scripts/load-ssh-key.sh
        ;;
esac
{{- end }}
